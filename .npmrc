# Workaround for n8n@2.x's internal peer-dep tangle (zod 3 vs 4 across the
# AI SDK family: @ai-sdk/anthropic, @ai-sdk/openai, langchain,
# @n8n/json-schema-to-zod, etc.). Without this flag npm 8+ aborts the
# install that @n8n/node-cli triggers for `n8n-node dev` / `n8n-node release`.
#
# Trade-off: peer conflicts elsewhere in the dep tree are silenced too.
# Revisit (drop the flag, or switch to package.json `overrides`) once n8n
# core de-tangles its zod 3 vs 4 split. Tracked in PR #3 (TASK-12569).
legacy-peer-deps=true
